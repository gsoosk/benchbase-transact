// MaxRecord10: 100% column coverage — all 249 data columns.
transaction MaxRecord10(keyname: int) {
    hops for i: int = 0 to SCAN_SIZE {
        var r: Row<htable> = htable[FIELD1: keyname + i];
        var v2: int = r.FIELD2; var v3: int = r.FIELD3; var v4: int = r.FIELD4;
        var v5: int = r.FIELD5; var v10: int = r.FIELD10; var v25: int = r.FIELD25;
        var v50: int = r.FIELD50; var v75: int = r.FIELD75; var v100: int = r.FIELD100;
        var v125: int = r.FIELD125; var v150: int = r.FIELD150; var v175: int = r.FIELD175;
        var v200: int = r.FIELD200; var v225: int = r.FIELD225; var v249: int = r.FIELD249;
        var v250: int = r.FIELD250;
    }
}

// ReadRecord1: SELECT FIELD1, FIELD2 FROM htable WHERE FIELD1 > keyname (1% cols)
transaction ReadRecord1(keyname: int) {
    hops for i: int = 0 to SCAN_SIZE {
        var r: Row<htable> = htable[FIELD1: keyname + i];
        var v2: int = r.FIELD2;
    }
}

// ReadRecord2: 10% column read coverage.
transaction ReadRecord2(keyname: int) {
    hops for i: int = 0 to SCAN_SIZE {
        var r: Row<htable> = htable[FIELD1: keyname + i];
        var v2: int = r.FIELD2; var v27: int = r.FIELD27; var v52: int = r.FIELD52;
        var v77: int = r.FIELD77; var v102: int = r.FIELD102;
    }
}

// ReadRecord3: 20% column read coverage.
transaction ReadRecord3(keyname: int) {
    hops for i: int = 0 to SCAN_SIZE {
        var r: Row<htable> = htable[FIELD1: keyname + i];
        var v2: int = r.FIELD2; var v7: int = r.FIELD7; var v12: int = r.FIELD12;
        var v17: int = r.FIELD17; var v22: int = r.FIELD22; var v27: int = r.FIELD27;
        var v52: int = r.FIELD52; var v77: int = r.FIELD77; var v102: int = r.FIELD102;
        var v127: int = r.FIELD127;
    }
}

