        var v50: int = r.FIELD50; var v100: int = r.FIELD100; var v125: int = r.FIELD125;
        var v150: int = r.FIELD150; var v175: int = r.FIELD175; var v200: int = r.FIELD200;
        var v225: int = r.FIELD225; var v248: int = r.FIELD248; var v250: int = r.FIELD250;
