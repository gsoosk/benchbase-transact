        var v20: int = r.FIELD20; var v50: int = r.FIELD50; var v75: int = r.FIELD75;
        var v100: int = r.FIELD100; var v125: int = r.FIELD125; var v150: int = r.FIELD150;
        var v175: int = r.FIELD175; var v200: int = r.FIELD200; var v225: int = r.FIELD225;
        var v250: int = r.FIELD250;
    }
}

