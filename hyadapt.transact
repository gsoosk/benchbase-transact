        var v2: int = r.FIELD2; var v4: int = r.FIELD4; var v6: int = r.FIELD6;
        var v8: int = r.FIELD8; var v10: int = r.FIELD10; var v25: int = r.FIELD25;
        var v50: int = r.FIELD50; var v75: int = r.FIELD75; var v100: int = r.FIELD100;
        var v125: int = r.FIELD125; var v150: int = r.FIELD150; var v175: int = r.FIELD175;
        var v200: int = r.FIELD200; var v225: int = r.FIELD225; var v240: int = r.FIELD240;
