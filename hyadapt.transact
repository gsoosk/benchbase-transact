        var v2: int = r.FIELD2; var v6: int = r.FIELD6; var v10: int = r.FIELD10;
        var v14: int = r.FIELD14; var v18: int = r.FIELD18; var v22: int = r.FIELD22;
        var v26: int = r.FIELD26; var v52: int = r.FIELD52; var v78: int = r.FIELD78;
        var v104: int = r.FIELD104; var v130: int = r.FIELD130; var v156: int = r.FIELD156;
        var v182: int = r.FIELD182; var v208: int = r.FIELD208; var v234: int = r.FIELD234;
    }
}

