    hop {
        user_observation_links[user_id: student_id, observer_id: observer_id, root_account_id: root_account_id] = {
            workflow_state: "active",
            sis_batch_id: 0
        };
    }
}

// Restore a previously deleted observer link.
// Models UserObservationLink.create_or_restore (restore branch).
transaction RestoreObservationLink(student_id: int, observer_id: int, root_account_id: int) {
    hop {
        user_observation_links[user_id: student_id, observer_id: observer_id, root_account_id: root_account_id].workflow_state = "active";
        user_observation_links[user_id: student_id, observer_id: observer_id, root_account_id: root_account_id].sis_batch_id = 0;
    }
}

// Soft-delete an observer link.
// Models UserObservationLink#destroy.
transaction DeleteObservationLink(student_id: int, observer_id: int, root_account_id: int) {
    hop {
        user_observation_links[user_id: student_id, observer_id: observer_id, root_account_id: root_account_id].workflow_state = "deleted";
    }
}

