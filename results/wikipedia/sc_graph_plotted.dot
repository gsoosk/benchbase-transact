  f19_i0_h7 -> f20_i0_h9 [dir=none, style="dotted,bold", color="#87CEEB", label="C (389.3ms)",penwidth=2.0];
  f19_i0_h7 -> f20_i0_h10 [dir=none, style="dotted,bold", color="#C8E86A", label="C (412.6ms)",penwidth=2.0];
  f19_i0_h7 -> f20_i1_h9 [dir=none, style="dotted,bold", color="#C2E676", label="C (410.3ms)",penwidth=2.0];
  f19_i0_h7 -> f20_i1_h10 [dir=none, style="dotted,bold", color="#FF0700", label="C (515.2ms)",penwidth=2.0];
