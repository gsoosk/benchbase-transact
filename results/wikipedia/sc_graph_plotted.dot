digraph SCGraph {
  graph [rankdir=LR];
  node  [shape=record, fontsize=10, fontname=Helvetica];
  edge  [fontname=Helvetica];
  // Legend for C-edge coloring
  subgraph cluster_legend {
    label="Verification Time (ms)";
    style=dashed;
    legend_0 [label="389.3 (Light Blue)", color="#87CEEB", style=filled, shape=box];
    legend_1 [label="431.9 (Yellow)", color="#FFFF00", style=filled, shape=box];
    legend_2 [label="474.6 (Orange)", color="#FFA500", style=filled, shape=box];
    legend_3 [label="517.3 (Red)", color="#FF0000", style=filled, shape=box];
    legend_4 [label="559.9 (Deep Red)", color="#8B0000", style=filled, shape=box];
    legend_0 -> legend_1 -> legend_2 -> legend_3 -> legend_4 [style=invis];
    legend_eliminated [label="Eliminated", style="dotted,bold", shape=box];
    legend_remaining [label="Remaining", style=dashed, shape=box];
    legend_eliminated -> legend_remaining [style=invis];
  }
  f16_i0_h1 [label="AddWatchList#0\nHop 1\n", style=filled, fillcolor="#FF9800"];
  f16_i1_h1 [label="AddWatchList#1\nHop 1\n", style=filled, fillcolor="#FFA500"];
  f17_i0_h2 [label="GetPageAnonymous#0\nHop 2\n"];
  f17_i0_h3 [label="GetPageAnonymous#0\nHop 3\n"];
  f17_i1_h2 [label="GetPageAnonymous#1\nHop 2\n"];
  f17_i1_h3 [label="GetPageAnonymous#1\nHop 3\n"];
  f18_i0_h4 [label="GetPageAuthenticated#0\nHop 4\n"];
  f18_i0_h5 [label="GetPageAuthenticated#0\nHop 5\n"];
  f18_i0_h6 [label="GetPageAuthenticated#0\nHop 6\n"];
  f18_i1_h4 [label="GetPageAuthenticated#1\nHop 4\n"];
  f18_i1_h5 [label="GetPageAuthenticated#1\nHop 5\n"];
  f18_i1_h6 [label="GetPageAuthenticated#1\nHop 6\n"];
  f19_i0_h7 [label="RemoveWatchList#0\nHop 7\n", style=filled, fillcolor="#FFDB00"];
  f19_i1_h7 [label="RemoveWatchList#1\nHop 7\n", style=filled, fillcolor="#FFCB00"];
  f20_i0_h8 [label="UpdatePage#0\nHop 8\n", style=filled, fillcolor="#FF3E00"];
  f20_i0_h9 [label="UpdatePage#0\nHop 9\n", style=filled, fillcolor="#FFD400"];
  f20_i0_h10 [label="UpdatePage#0\nHop 10\n", style=filled, fillcolor="#FFEE00"];
  f20_i1_h8 [label="UpdatePage#1\nHop 8\n", style=filled, fillcolor="#FF3E00"];
  f20_i1_h9 [label="UpdatePage#1\nHop 9\n", style=filled, fillcolor="#FF8100"];
  f20_i1_h10 [label="UpdatePage#1\nHop 10\n", style=filled, fillcolor="#FF2D00"];
  f17_i0_h2 -> f17_i0_h3 [color=black, label="S"];
  f17_i1_h2 -> f17_i1_h3 [color=black, label="S"];
  f18_i0_h4 -> f18_i0_h5 [color=black, label="S"];
  f18_i0_h5 -> f18_i0_h6 [color=black, label="S"];
  f18_i1_h4 -> f18_i1_h5 [color=black, label="S"];
  f18_i1_h5 -> f18_i1_h6 [color=black, label="S"];
