digraph SCGraph {
  graph [rankdir=LR];
  node  [shape=record, fontsize=10, fontname=Helvetica];
  edge  [fontname=Helvetica];
  // Legend for C-edge coloring
  subgraph cluster_legend {
    label="Verification Time (ms)";
    style=dashed;
    legend_0 [label="237.1 (Light Blue)", color="#87CEEB", style=filled, shape=box];
    legend_1 [label="431.3 (Yellow)", color="#FFFF00", style=filled, shape=box];
    legend_2 [label="625.5 (Orange)", color="#FFA500", style=filled, shape=box];
    legend_3 [label="819.7 (Red)", color="#FF0000", style=filled, shape=box];
    legend_4 [label="1013.9 (Deep Red)", color="#8B0000", style=filled, shape=box];
    legend_0 -> legend_1 -> legend_2 -> legend_3 -> legend_4 [style=invis];
    legend_eliminated [label="Eliminated", style="dotted,bold", shape=box];
    legend_remaining [label="Remaining", style=dashed, shape=box];
    legend_eliminated -> legend_remaining [style=invis];
  }
  f16_i0_h1 [label="GenericRead#0\nHop 1\n"];
  f16_i1_h1 [label="GenericRead#1\nHop 1\n"];
  f17_i0_h2 [label="GenericUpdate#0\nHop 2\n", style=filled, fillcolor="#FF9800"];
  f17_i1_h2 [label="GenericUpdate#1\nHop 2\n", style=filled, fillcolor="#FF8800"];
  f18_i0_h3 [label="GenericInsert#0\nHop 3\n", style=filled, fillcolor="#FF5B00"];
  f18_i1_h3 [label="GenericInsert#1\nHop 3\n", style=filled, fillcolor="#FF3200"];
  f19_i0_h4 [label="GenericReadModifyWrite#0\nHop 4\n", style=filled, fillcolor="#FF9A00"];
  f19_i0_h5 [label="GenericReadModifyWrite#0\nHop 5\n", style=filled, fillcolor="#FFEE00"];
  f19_i1_h4 [label="GenericReadModifyWrite#1\nHop 4\n", style=filled, fillcolor="#FF1E00"];
  f19_i1_h5 [label="GenericReadModifyWrite#1\nHop 5\n", style=filled, fillcolor="#FFDE00"];
  f19_i0_h4 -> f19_i0_h5 [color=black, label="S"];
  f19_i1_h4 -> f19_i1_h5 [color=black, label="S"];
  f17_i0_h2 -> f17_i1_h2 [dir=none, style="dotted,bold", color="#FFD600", label="C (519.6ms)",penwidth=2.0];
  f17_i0_h2 -> f18_i0_h3 [dir=none, style="dotted,bold", color="#FFCD00", label="C (538.2ms)",penwidth=2.0];
  f17_i0_h2 -> f18_i1_h3 [dir=none, style="dotted,bold", color="#FFBF00", label="C (567.7ms)",penwidth=2.0];
  f17_i0_h2 -> f19_i0_h4 [dir=none, style="dotted,bold", color="#8D0000", label="C (1009.3ms)",penwidth=2.0];
  f17_i0_h2 -> f19_i0_h5 [dir=none, style="dotted,bold", color="#FF9D00", label="C (634.2ms)",penwidth=2.0];
  f17_i0_h2 -> f19_i1_h4 [dir=none, style="dotted,bold", color="#A20000", label="C (975.2ms)",penwidth=2.0];
  f17_i0_h2 -> f19_i1_h5 [dir=none, style="dotted,bold", color="#87CEEB", label="C (237.1ms)",penwidth=2.0];
  f17_i1_h2 -> f18_i0_h3 [dir=none, style="dotted,bold", color="#FFC600", label="C (553.4ms)",penwidth=2.0];
  f17_i1_h2 -> f18_i1_h3 [dir=none, style="dotted,bold", color="#FF3A00", label="C (750.7ms)",penwidth=2.0];
  f17_i1_h2 -> f19_i0_h4 [dir=none, style="dotted,bold", color="#FFBC00", label="C (574.1ms)",penwidth=2.0];
  f17_i1_h2 -> f19_i0_h5 [dir=none, style="dotted,bold", color="#FF7F00", label="C (669.8ms)",penwidth=2.0];
  f17_i1_h2 -> f19_i1_h4 [dir=none, style="dotted,bold", color="#FF1300", label="C (796.5ms)",penwidth=2.0];
  f17_i1_h2 -> f19_i1_h5 [dir=none, style="dotted,bold", color="#FF3900", label="C (752.0ms)",penwidth=2.0];
  f18_i0_h3 -> f18_i1_h3 [dir=none, style="dotted,bold", color="#8B0000", label="C (1013.9ms)",penwidth=2.0];
  f18_i0_h3 -> f19_i0_h4 [dir=none, style="dotted,bold", color="#FF2C00", label="C (766.7ms)",penwidth=2.0];
  f18_i0_h3 -> f19_i0_h5 [dir=none, style="dotted,bold", color="#FFC100", label="C (563.3ms)",penwidth=2.0];
  f18_i0_h3 -> f19_i1_h4 [dir=none, style="dotted,bold", color="#8C0000", label="C (1011.8ms)",penwidth=2.0];
  f18_i0_h3 -> f19_i1_h5 [dir=none, style="dotted,bold", color="#FFCF00", label="C (533.6ms)",penwidth=2.0];
  f18_i1_h3 -> f19_i0_h4 [dir=none, style="dotted,bold", color="#FF3B00", label="C (750.2ms)",penwidth=2.0];
  f18_i1_h3 -> f19_i0_h5 [dir=none, style="dotted,bold", color="#8DD0DE", label="C (247.5ms)",penwidth=2.0];
  f18_i1_h3 -> f19_i1_h4 [dir=none, style="dotted,bold", color="#8D0000", label="C (1009.2ms)",penwidth=2.0];
  f18_i1_h3 -> f19_i1_h5 [dir=none, style="dotted,bold", color="#9C0000", label="C (983.9ms)",penwidth=2.0];
  f19_i0_h4 -> f19_i1_h4 [dir=none, style="dotted,bold", color="#FFEB00", label="C (473.1ms)",penwidth=2.0];
  f19_i0_h4 -> f19_i1_h5 [dir=none, style="dotted,bold", color="#8FD1D9", label="C (251.2ms)",penwidth=2.0];
  f19_i0_h5 -> f19_i1_h5 [dir=none, style="dotted,bold", color="#8ED0DD", label="C (248.7ms)",penwidth=2.0];
  f19_i1_h4 -> f19_i0_h5 [dir=none, style="dotted,bold", color="#FFFC00", label="C (437.3ms)",penwidth=2.0];
}
