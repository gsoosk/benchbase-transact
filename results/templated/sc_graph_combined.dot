digraph CombinedSCGraph {
  graph [rankdir=LR];
  node  [shape=record, fontsize=10, fontname=Helvetica];
  edge  [fontname=Helvetica];
  cv0 [label="GenericRead#1\nHop 1\n"];
  cv1 [label="GenericRead#0\nHop 1\n"];
  cv2 [label="GenericUpdate#0\nHop 2\n"];
  cv3 [label="GenericUpdate#1\nHop 2\n"];
  cv4 [label="GenericInsert#0\nHop 3\n"];
  cv5 [label="GenericInsert#1\nHop 3\n"];
  cv6 [label="GenericReadModifyWrite#0\nHop 4, 5\n"];
  cv7 [label="GenericReadModifyWrite#1\nHop 4, 5\n"];
  cv2 -> cv3 [dir=none, style=dashed, color=darkorange, label="C"];
  cv2 -> cv4 [dir=none, style=dashed, color=darkorange, label="C"];
  cv2 -> cv5 [dir=none, style=dashed, color=darkorange, label="C"];
  cv2 -> cv6 [dir=none, style=dashed, color=darkorange, label="C"];
  cv2 -> cv7 [dir=none, style=dashed, color=darkorange, label="C"];
  cv3 -> cv4 [dir=none, style=dashed, color=darkorange, label="C"];
  cv3 -> cv5 [dir=none, style=dashed, color=darkorange, label="C"];
  cv3 -> cv6 [dir=none, style=dashed, color=darkorange, label="C"];
  cv3 -> cv7 [dir=none, style=dashed, color=darkorange, label="C"];
  cv4 -> cv5 [dir=none, style=dashed, color=darkorange, label="C"];
  cv4 -> cv6 [dir=none, style=dashed, color=darkorange, label="C"];
  cv4 -> cv7 [dir=none, style=dashed, color=darkorange, label="C"];
  cv5 -> cv6 [dir=none, style=dashed, color=darkorange, label="C"];
  cv5 -> cv7 [dir=none, style=dashed, color=darkorange, label="C"];
  cv6 -> cv7 [dir=none, style=dashed, color=darkorange, label="C"];
}
