digraph SCGraph {
  graph [rankdir=LR];
  node  [shape=record, fontsize=10, fontname=Helvetica];
  edge  [fontname=Helvetica];
  // Legend for C-edge coloring
  subgraph cluster_legend {
    label="Verification Time (ms)";
    style=dashed;
    legend_0 [label="354.6 (Light Blue)", color="#87CEEB", style=filled, shape=box];
    legend_1 [label="354.6 (Yellow)", color="#FFFF00", style=filled, shape=box];
    legend_2 [label="354.6 (Orange)", color="#FFA500", style=filled, shape=box];
    legend_3 [label="354.6 (Red)", color="#FF0000", style=filled, shape=box];
    legend_4 [label="354.6 (Deep Red)", color="#8B0000", style=filled, shape=box];
    legend_0 -> legend_1 -> legend_2 -> legend_3 -> legend_4 [style=invis];
    legend_eliminated [label="Eliminated", style="dotted,bold", shape=box];
    legend_remaining [label="Remaining", style=dashed, shape=box];
    legend_eliminated -> legend_remaining [style=invis];
  }
  f16_i0_h1 [label="GetFollowers#0\nHop 1\n"];
  f16_i0_h2 [label="GetFollowers#0\nHop 2\n"];
  f16_i1_h1 [label="GetFollowers#1\nHop 1\n"];
  f16_i1_h2 [label="GetFollowers#1\nHop 2\n"];
  f17_i0_h3 [label="GetTweet#0\nHop 3\n"];
  f17_i1_h3 [label="GetTweet#1\nHop 3\n"];
  f18_i0_h4 [label="GetTweetsFromFollowing#0\nHop 4\n"];
  f18_i0_h5 [label="GetTweetsFromFollowing#0\nHop 5\n"];
  f18_i1_h4 [label="GetTweetsFromFollowing#1\nHop 4\n"];
  f18_i1_h5 [label="GetTweetsFromFollowing#1\nHop 5\n"];
  f19_i0_h6 [label="GetUserTweets#0\nHop 6\n"];
  f19_i1_h6 [label="GetUserTweets#1\nHop 6\n"];
  f20_i0_h7 [label="InsertTweet#0\nHop 7\n", style=filled, fillcolor="#FFA500"];
  f20_i1_h7 [label="InsertTweet#1\nHop 7\n", style=filled, fillcolor="#FFA500"];
  f16_i0_h1 -> f16_i0_h2 [color=black, label="S"];
  f16_i1_h1 -> f16_i1_h2 [color=black, label="S"];
  f18_i0_h4 -> f18_i0_h5 [color=black, label="S"];
  f18_i1_h4 -> f18_i1_h5 [color=black, label="S"];
  f20_i0_h7 -> f20_i1_h7 [dir=none, style="dotted,bold", color="#FFA500", label="C (354.6ms)",penwidth=2.0];
}
