digraph CombinedSCGraph {
  graph [rankdir=LR];
  node  [shape=record, fontsize=10, fontname=Helvetica];
  edge  [fontname=Helvetica];
  cv0 [label="Vote#0\nHop 3\n"];
  cv1 [label="Vote#0\nHop 4\n"];
  cv2 [label="Vote#1\nHop 3\n"];
  cv3 [label="Vote#1\nHop 4\n"];
  cv4 [label="Vote#0\nHop 5\n"];
  cv5 [label="Vote#1\nHop 5\n"];
  cv0 -> cv1 [color=black, label="S"];
  cv1 -> cv4 [color=black, label="S"];
  cv2 -> cv3 [color=black, label="S"];
  cv3 -> cv5 [color=black, label="S"];
  cv4 -> cv5 [dir=none, style=dashed, color=darkorange, label="C"];
}
