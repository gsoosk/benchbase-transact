digraph SCGraph {
  graph [rankdir=LR];
  node  [shape=record, fontsize=10, fontname=Helvetica];
  edge  [fontname=Helvetica];
  // Legend for C-edge coloring
  subgraph cluster_legend {
    label="Verification Time (ms)";
    style=dashed;
    legend_0 [label="226.2 (Light Blue)", color="#87CEEB", style=filled, shape=box];
    legend_1 [label="300.8 (Yellow)", color="#FFFF00", style=filled, shape=box];
    legend_2 [label="375.5 (Orange)", color="#FFA500", style=filled, shape=box];
    legend_3 [label="450.1 (Red)", color="#FF0000", style=filled, shape=box];
    legend_4 [label="524.7 (Deep Red)", color="#8B0000", style=filled, shape=box];
    legend_0 -> legend_1 -> legend_2 -> legend_3 -> legend_4 [style=invis];
    legend_eliminated [label="Eliminated", style="dotted,bold", shape=box];
    legend_remaining [label="Remaining", style=dashed, shape=box];
    legend_eliminated -> legend_remaining [style=invis];
  }
  f16_i0_h1 [label="DeleteCallForwarding#0\nHop 1\n", style=filled, fillcolor="#FF8200"];
  f16_i1_h1 [label="DeleteCallForwarding#1\nHop 1\n", style=filled, fillcolor="#FF8600"];
  f17_i0_h2 [label="GetAccessData#0\nHop 2\n"];
  f17_i1_h2 [label="GetAccessData#1\nHop 2\n"];
  f18_i0_h3 [label="GetNewDestination#0\nHop 3\n", style=filled, fillcolor="#FF3500"];
  f18_i1_h3 [label="GetNewDestination#1\nHop 3\n", style=filled, fillcolor="#FF4200"];
  f19_i0_h4 [label="GetSubscriberData#0\nHop 4\n", style=filled, fillcolor="#FF7800"];
  f19_i1_h4 [label="GetSubscriberData#1\nHop 4\n", style=filled, fillcolor="#FF5E00"];
  f20_i0_h5 [label="InsertCallForwarding#0\nHop 5\n", style=filled, fillcolor="#FFAE00"];
  f20_i1_h5 [label="InsertCallForwarding#1\nHop 5\n", style=filled, fillcolor="#FF7400"];
  f21_i0_h6 [label="UpdateLocation#0\nHop 6\n", style=filled, fillcolor="#FF9B00"];
  f21_i1_h6 [label="UpdateLocation#1\nHop 6\n", style=filled, fillcolor="#FF9B00"];
  f22_i0_h7 [label="UpdateSubscriberData#0\nHop 7\n", style=filled, fillcolor="#FF8600"];
  f22_i1_h7 [label="UpdateSubscriberData#1\nHop 7\n", style=filled, fillcolor="#FFA800"];
  f16_i0_h1 -> f20_i0_h5 [dir=none, style="dotted,bold", color="#FFD300", label="C (336.5ms)",penwidth=2.0];
  f16_i0_h1 -> f20_i1_h5 [dir=none, style="dotted,bold", color="#FF0800", label="C (446.1ms)",penwidth=2.0];
  f16_i1_h1 -> f20_i0_h5 [dir=none, style="dotted,bold", color="#FFF100", label="C (311.9ms)",penwidth=2.0];
  f16_i1_h1 -> f20_i1_h5 [dir=none, style="dotted,bold", color="#E50000", label="C (466.5ms)",penwidth=2.0];
  f18_i0_h3 -> f20_i0_h5 [dir=none, style="dotted,bold", color="#FFAC00", label="C (369.4ms)",penwidth=2.0];
  f18_i0_h3 -> f20_i1_h5 [dir=none, style="dotted,bold", color="#FF4100", label="C (420.3ms)",penwidth=2.0];
  f18_i0_h3 -> f22_i0_h7 [dir=none, style="dotted,bold", color="#960000", label="C (517.5ms)",penwidth=2.0];
  f18_i0_h3 -> f22_i1_h7 [dir=none, style="dotted,bold", color="#FF7500", label="C (396.8ms)",penwidth=2.0];
  f18_i1_h3 -> f20_i0_h5 [dir=none, style="dotted,bold", color="#FF9F00", label="C (377.9ms)",penwidth=2.0];
  f18_i1_h3 -> f20_i1_h5 [dir=none, style="dotted,bold", color="#FF0800", label="C (446.1ms)",penwidth=2.0];
  f18_i1_h3 -> f22_i0_h7 [dir=none, style="dotted,bold", color="#E70000", label="C (465.0ms)",penwidth=2.0];
  f18_i1_h3 -> f22_i1_h7 [dir=none, style="dotted,bold", color="#FF8400", label="C (390.4ms)",penwidth=2.0];
  f19_i0_h4 -> f21_i0_h6 [dir=none, style="dotted,bold", color="#FFBF00", label="C (353.3ms)",penwidth=2.0];
  f19_i0_h4 -> f21_i1_h6 [dir=none, style="dotted,bold", color="#FF2F00", label="C (428.7ms)",penwidth=2.0];
  f19_i0_h4 -> f22_i0_h7 [dir=none, style="dotted,bold", color="#FF7A00", label="C (394.6ms)",penwidth=2.0];
  f19_i0_h4 -> f22_i1_h7 [dir=none, style="dotted,bold", color="#FF6000", label="C (406.2ms)",penwidth=2.0];
  f19_i1_h4 -> f21_i0_h6 [dir=none, style="dotted,bold", color="#8B0000", label="C (524.7ms)",penwidth=2.0];
  f19_i1_h4 -> f21_i1_h6 [dir=none, style="dotted,bold", color="#FFB800", label="C (359.3ms)",penwidth=2.0];
  f19_i1_h4 -> f22_i0_h7 [dir=none, style="dotted,bold", color="#FFA300", label="C (376.2ms)",penwidth=2.0];
  f19_i1_h4 -> f22_i1_h7 [dir=none, style="dotted,bold", color="#FFAB00", label="C (369.8ms)",penwidth=2.0];
  f20_i0_h5 -> f20_i1_h5 [dir=none, style="dotted,bold", color="#FFAA00", label="C (370.5ms)",penwidth=2.0];
  f20_i0_h5 -> f21_i0_h6 [dir=none, style="dotted,bold", color="#FFB500", label="C (362.1ms)",penwidth=2.0];
  f20_i0_h5 -> f21_i1_h6 [dir=none, style="dotted,bold", color="#FFC200", label="C (351.2ms)",penwidth=2.0];
  f20_i0_h5 -> f22_i0_h7 [dir=none, style="dotted,bold", color="#FF5700", label="C (410.4ms)",penwidth=2.0];
  f20_i0_h5 -> f22_i1_h7 [dir=none, style="dotted,bold", color="#FF4300", label="C (419.6ms)",penwidth=2.0];
  f20_i1_h5 -> f21_i0_h6 [dir=none, style="dotted,bold", color="#91D2D7", label="C (232.5ms)",penwidth=2.0];
  f20_i1_h5 -> f21_i1_h6 [dir=none, style="dotted,bold", color="#FFA900", label="C (371.9ms)",penwidth=2.0];
  f20_i1_h5 -> f22_i0_h7 [dir=none, style="dotted,bold", color="#FF7700", label="C (396.2ms)",penwidth=2.0];
  f20_i1_h5 -> f22_i1_h7 [dir=none, style="dotted,bold", color="#FF3500", label="C (426.1ms)",penwidth=2.0];
  f21_i0_h6 -> f21_i1_h6 [dir=none, style="dotted,bold", color="#FD0000", label="C (450.8ms)",penwidth=2.0];
  f21_i0_h6 -> f22_i0_h7 [dir=none, style="dotted,bold", color="#FFC200", label="C (350.8ms)",penwidth=2.0];
  f21_i0_h6 -> f22_i1_h7 [dir=none, style="dotted,bold", color="#FF9000", label="C (384.5ms)",penwidth=2.0];
  f21_i1_h6 -> f22_i0_h7 [dir=none, style="dotted,bold", color="#FFB100", label="C (365.2ms)",penwidth=2.0];
  f21_i1_h6 -> f22_i1_h7 [dir=none, style="dotted,bold", color="#FFD900", label="C (331.5ms)",penwidth=2.0];
  f22_i0_h7 -> f22_i1_h7 [dir=none, style="dotted,bold", color="#87CEEB", label="C (226.2ms)",penwidth=2.0];
}
