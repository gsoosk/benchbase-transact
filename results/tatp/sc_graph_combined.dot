digraph CombinedSCGraph {
  graph [rankdir=LR];
  node  [shape=record, fontsize=10, fontname=Helvetica];
  edge  [fontname=Helvetica];
  cv0 [label="DeleteCallForwarding#0\nHop 1\n"];
  cv1 [label="DeleteCallForwarding#1\nHop 1\n"];
  cv2 [label="GetSubscriberData#1\nHop 4\n"];
  cv3 [label="InsertCallForwarding#0\nHop 5\n"];
  cv4 [label="InsertCallForwarding#1\nHop 5\n"];
  cv5 [label="GetSubscriberData#0\nHop 4\n"];
  cv6 [label="GetNewDestination#0\nHop 3\n"];
  cv7 [label="GetNewDestination#1\nHop 3\n"];
  cv8 [label="UpdateLocation#0\nHop 6\n"];
  cv9 [label="UpdateLocation#1\nHop 6\n"];
  cv10 [label="UpdateSubscriberData#0\nHop 7\n"];
  cv11 [label="UpdateSubscriberData#1\nHop 7\n"];
  cv12 [label="GetAccessData#1\nHop 2\n"];
  cv13 [label="GetAccessData#0\nHop 2\n"];
  cv3 -> cv4 [dir=none, style=dashed, color=darkorange, label="C"];
  cv6 -> cv10 [dir=none, style=dashed, color=darkorange, label="C"];
  cv6 -> cv11 [dir=none, style=dashed, color=darkorange, label="C"];
  cv7 -> cv10 [dir=none, style=dashed, color=darkorange, label="C"];
  cv7 -> cv11 [dir=none, style=dashed, color=darkorange, label="C"];
  cv8 -> cv9 [dir=none, style=dashed, color=darkorange, label="C"];
  cv8 -> cv10 [dir=none, style=dashed, color=darkorange, label="C"];
  cv8 -> cv11 [dir=none, style=dashed, color=darkorange, label="C"];
  cv9 -> cv10 [dir=none, style=dashed, color=darkorange, label="C"];
  cv9 -> cv11 [dir=none, style=dashed, color=darkorange, label="C"];
  cv10 -> cv11 [dir=none, style=dashed, color=darkorange, label="C"];
}
