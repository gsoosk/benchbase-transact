digraph SCGraph {
  graph [rankdir=LR];
  node  [shape=record, fontsize=10, fontname=Helvetica];
  edge  [fontname=Helvetica];
  // Legend for C-edge coloring
  subgraph cluster_legend {
    label="Verification Time (ms)";
    style=dashed;
    legend_0 [label="324.5 (Light Blue)", color="#87CEEB", style=filled, shape=box];
    legend_1 [label="393.0 (Yellow)", color="#FFFF00", style=filled, shape=box];
    legend_2 [label="461.6 (Orange)", color="#FFA500", style=filled, shape=box];
    legend_3 [label="530.1 (Red)", color="#FF0000", style=filled, shape=box];
    legend_4 [label="598.6 (Deep Red)", color="#8B0000", style=filled, shape=box];
    legend_0 -> legend_1 -> legend_2 -> legend_3 -> legend_4 [style=invis];
    legend_eliminated [label="Eliminated", style="dotted,bold", shape=box];
    legend_remaining [label="Remaining", style=dashed, shape=box];
    legend_eliminated -> legend_remaining [style=invis];
  }
  f17_i0_h2 [label="GetAverageRatingByTrustedUser#0\nHop 2\n"];
  f17_i0_h3 [label="GetAverageRatingByTrustedUser#0\nHop 3\n"];
  f17_i1_h2 [label="GetAverageRatingByTrustedUser#1\nHop 2\n"];
  f17_i1_h3 [label="GetAverageRatingByTrustedUser#1\nHop 3\n"];
  f18_i0_h4 [label="GetItemAverageRating#0\nHop 4\n"];
  f18_i1_h4 [label="GetItemAverageRating#1\nHop 4\n"];
  f19_i0_h5 [label="GetItemReviewsByTrustedUser#0\nHop 5\n"];
  f19_i0_h6 [label="GetItemReviewsByTrustedUser#0\nHop 6\n"];
  f19_i1_h5 [label="GetItemReviewsByTrustedUser#1\nHop 5\n"];
  f19_i1_h6 [label="GetItemReviewsByTrustedUser#1\nHop 6\n"];
  f20_i0_h7 [label="GetReviewItemById#0\nHop 7\n"];
  f20_i1_h7 [label="GetReviewItemById#1\nHop 7\n"];
  f21_i0_h8 [label="GetReviewsByUser#0\nHop 8\n"];
  f21_i0_h9 [label="GetReviewsByUser#0\nHop 9\n"];
  f21_i1_h8 [label="GetReviewsByUser#1\nHop 8\n"];
  f21_i1_h9 [label="GetReviewsByUser#1\nHop 9\n"];
  f22_i0_h10 [label="UpdateItemTitle#0\nHop 10\n", style=filled, fillcolor="#8B0000"];
  f22_i1_h10 [label="UpdateItemTitle#1\nHop 10\n", style=filled, fillcolor="#8B0000"];
  f23_i0_h11 [label="UpdateReviewRating#0\nHop 11\n", style=filled, fillcolor="#8ED1DB"];
  f23_i1_h11 [label="UpdateReviewRating#1\nHop 11\n", style=filled, fillcolor="#8ED1DB"];
  f24_i0_h12 [label="UpdateTrustRating#0\nHop 12\n", style=filled, fillcolor="#A3D9B3"];
  f24_i1_h12 [label="UpdateTrustRating#1\nHop 12\n", style=filled, fillcolor="#A3D9B3"];
  f25_i0_h13 [label="UpdateUserName#0\nHop 13\n", style=filled, fillcolor="#87CEEB"];
  f25_i1_h13 [label="UpdateUserName#1\nHop 13\n", style=filled, fillcolor="#87CEEB"];
  f17_i0_h2 -> f17_i0_h3 [color=black, label="S"];
  f17_i1_h2 -> f17_i1_h3 [color=black, label="S"];
  f19_i0_h5 -> f19_i0_h6 [color=black, label="S"];
  f19_i1_h5 -> f19_i1_h6 [color=black, label="S"];
  f21_i0_h8 -> f21_i0_h9 [color=black, label="S"];
  f21_i1_h8 -> f21_i1_h9 [color=black, label="S"];
  f22_i0_h10 -> f22_i1_h10 [dir=none, style="dotted,bold", color="#8B0000", label="C (598.6ms)",penwidth=2.0];
  f23_i0_h11 -> f23_i1_h11 [dir=none, style="dotted,bold", color="#8ED1DB", label="C (329.0ms)",penwidth=2.0];
  f24_i0_h12 -> f24_i1_h12 [dir=none, style="dotted,bold", color="#A3D9B3", label="C (340.7ms)",penwidth=2.0];
  f25_i0_h13 -> f25_i1_h13 [dir=none, style="dotted,bold", color="#87CEEB", label="C (324.5ms)",penwidth=2.0];
}
