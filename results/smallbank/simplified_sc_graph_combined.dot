digraph CombinedSCGraph {
  graph [rankdir=LR];
  node  [shape=record, fontsize=10, fontname=Helvetica];
  edge  [fontname=Helvetica];
  cv0 [label="Balance#1\nHop 3\n"];
  cv1 [label="TransactSavings#1\nHop 7\n"];
  cv2 [label="DepositChecking#0\nHop 4\n"];
  cv3 [label="TransactSavings#0\nHop 7\n"];
  cv4 [label="Amalgamate#1\nHop 1\n"];
  cv5 [label="Amalgamate#0\nHop 1\n"];
  cv6 [label="SendPayment#0\nHop 5\n"];
  cv7 [label="WriteCheck#0\nHop 8\n"];
  cv8 [label="Balance#0\nHop 3\n"];
  cv9 [label="SendPayment#0\nHop 6\n"];
  cv10 [label="WriteCheck#1\nHop 8\n"];
  cv11 [label="SendPayment#1\nHop 5\n"];
  cv12 [label="SendPayment#1\nHop 6\n"];
  cv13 [label="Amalgamate#0\nHop 2\n"];
  cv14 [label="Amalgamate#1\nHop 2\n"];
  cv15 [label="DepositChecking#1\nHop 4\n"];
  cv4 -> cv14 [color=black, label="S"];
  cv5 -> cv13 [color=black, label="S"];
  cv6 -> cv9 [color=black, label="S"];
  cv11 -> cv12 [color=black, label="S"];
}
