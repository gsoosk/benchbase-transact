digraph SCGraph {
  graph [rankdir=LR];
  node  [shape=record, fontsize=10, fontname=Helvetica];
  edge  [fontname=Helvetica];
  // Legend for C-edge coloring
  subgraph cluster_legend {
    label="Verification Time (ms)";
    style=dashed;
    legend_0 [label="0.0 (Light Blue)", color="#87CEEB", style=filled, shape=box];
    legend_1 [label="0.0 (Yellow)", color="#FFFF00", style=filled, shape=box];
    legend_2 [label="0.0 (Orange)", color="#FFA500", style=filled, shape=box];
    legend_3 [label="0.0 (Red)", color="#FF0000", style=filled, shape=box];
    legend_4 [label="0.0 (Deep Red)", color="#8B0000", style=filled, shape=box];
    legend_0 -> legend_1 -> legend_2 -> legend_3 -> legend_4 [style=invis];
    legend_eliminated [label="Eliminated", style="dotted,bold", shape=box];
    legend_remaining [label="Remaining", style=dashed, shape=box];
    legend_eliminated -> legend_remaining [style=invis];
  }
  f16_i0_h1 [label="Amalgamate#0\nHop 1\n", style=filled, fillcolor="#FFA500"];
  f16_i0_h2 [label="Amalgamate#0\nHop 2\n", style=filled, fillcolor="#FFA500"];
  f16_i1_h1 [label="Amalgamate#1\nHop 1\n", style=filled, fillcolor="#FFA500"];
  f16_i1_h2 [label="Amalgamate#1\nHop 2\n", style=filled, fillcolor="#FFA500"];
  f17_i0_h3 [label="Balance#0\nHop 3\n"];
  f17_i1_h3 [label="Balance#1\nHop 3\n"];
